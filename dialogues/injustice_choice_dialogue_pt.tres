lines = Array[String](["\"Sim, é mais justo que eu fique preso por toda eternidade em um mundo quebrado", "Sozinho e esquecido…", "pode ir embora…", "", "Ou pode ficar e me ajudar! Vou te mostrar o trabalho de qualquer forma mesmo."])
