script = ExtResource("1_4d485")
long_text = "import 'package:flutter/material.dart';
import 'player.dart';

class  {
  const CloudWidget({super.key});

  @override
  Widget build(BuildContext context) {
    final player = Player();

    return AnimatedBuilder(
      animation: player,
      builder: (context, child) {
        if (!player.getHasCloud()) return const SizedBox.shrink();

        final position = player.getPosition();

        return Positioned(
          left: position[0] - 10,
          top: position[1] - 30,
          child: Image.asset(
            'assets/img/char/cloud.png', // Nome do seu asset
            width: 80,
            height: 40,
            fit: BoxFit.contain,
          ),
        );
      },
    );
  }
} "
metadata/_custom_type_script = "uid://b8ttwtxu3cyox"
