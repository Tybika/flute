script = ExtResource("1_8bb7t")
long_text = "import 'dart:core';
import 'package:flutter/material.dart';
import 'package:flutter_calc/player.dart';


class LifeWidget extends StatefulWidget {
  const LifeWidget({super.key});

  @override
  State<LifeWidget> createState() => _LifeWidgetState();
}

class _LifeWidgetState extends State<LifeWidget> {
  final player = Player();

  @override
  void initState() {
    super.initState();

    player.addListener(_update);
  }

  @override
  void dispose() {
    player.removeListener(_update);
    super.dispose();
  }

  void _update() {
    setState(() {});
  }

  @override
  Widget build(BuildContext context) {
    return Row(
      children: List.generate(
        3,
            (index) {
          final hasLife = index < player.getCurrentLife();

          return Image.asset(
            hasLife
                ? 'assets/heart_fill_32.png'
                : 'assets/heart_outline_32.png',
            width: 32,
            height: 32,
          );
        },
      ),
    );
  }
}"
metadata/_custom_type_script = "uid://b8ttwtxu3cyox"
