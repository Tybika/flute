script = ExtResource("1_7f4ex")
long_text = "import 'package:flutter/material.dart';
import 'package:flutter_calc/coinWidget.dart';
import 'package:flutter_calc/joystick.dart';
import 'package:flutter_calc/life_counter.dart';

class GameHud extends StatelessWidget {
  const GameHud({super.key});

  @override
  Widget build(BuildContext context) {
    final size = MediaQuery
        .of(context)
        .size;

    return _(
      width: size.width,
      height: size.height,
      padding: const EdgeInsets.all(16.0),
      child: _(
        mainAxisAlignment: MainAxisAlignment.spaceBetween,
        children: [
          _(
            mainAxisAlignment: MainAxisAlignment.spaceBetween,
            children: [
                  LifeWidget(),
                  CoinWidget(),
                ],
              ),
          _(
            alignment: Alignment.bottomRight,
            child: SizedBox(
              child: const Center(
                child: MyJoystick(),
              ),
            ),
          ),
        ],
      ),
    );
  }
} "
