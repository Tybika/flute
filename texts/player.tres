[resource]
script = ExtResource("1_4g0j2")
long_text = "import 'package:flutter/cupertino.dart';


class Player extends ChangeNotifier {
  static final Player _instance = Player._internal();

  factory Player() {
    return _instance;
  }

  Player._internal();

  static const _speed = 10.0;
  final int _totalLife = 15;
  int _currentLife = 1;
  int _coinAmount = 0;
  double _xPos = 480;
  double _yPos = 350;
  String _currentAssetName = 'player_idle.png';
  bool _hasCloud = false;


  static double getSpeed(){
    return _speed;
  }

  int getCurrentLife(){
    return _currentLife;
  }

  int getTotalLife() {
    return _totalLife;
  }

  int getCoinAmount() {
    return _coinAmount;
  }

  List<double> getPosition() {
    List<double> position = [_xPos, _yPos];
    return position;
  }

  String getCurrentAssetPath() {
    return 'assets/img/char/$_currentAssetName';
  }

  bool getHasCloud() {
    return _hasCloud;
  }

  void setPosition(double x, double y) {
    _xPos = x;
    _yPos = y;
  }

  void setCurrentAssetName(String name) {
    _currentAssetName = name;
    notifyListeners();
  }

  void collectCloud() {
    _hasCloud = true;
    notifyListeners();
  }

  void damage([int value = 1]) {
    if (_hasCloud) {
    _hasCloud = false;
    }
    else {
  _currentLife -= value;

  if (_currentLife < 0) {
  _currentLife = 1;
  }
  }
    notifyListeners();
  }

  void heal([int value = 1]) {
    _currentLife += value;

    if (_currentLife > _totalLife) {
      _currentLife = _totalLife;
    }

    notifyListeners();
  }

  void gainCoin(int amount) {
    _coinAmount += amount;

    notifyListeners();
  }

  void wasteCoin(int amount) {
    _coinAmount -= amount;

    notifyListeners();
  }

  void move([double ?xMove, double ?yMove]) {
    if (xMove != null){
      _xPos += xMove;
    }

    if (yMove != null){
      _yPos += yMove;
    }

    notifyListeners();
  }

  void moveOrigin(){
    _xPos = 0;
    _yPos = 350;
  }

}"
metadata/_custom_type_script = "uid://b8ttwtxu3cyox"
